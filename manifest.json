{
  "manifest_version": 3,
  "name": "Study Focus Timer",
  "version": "1.0.0",
  "description": "Track study sessions and focus score. Coding mode detects VS Code switches without penalizing your score.",

  "action": {
    "default_popup": "index.html",
    "default_title": "Study Focus Timer",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
